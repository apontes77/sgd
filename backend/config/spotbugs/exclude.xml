<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Entidades JPA e records de API usam getters/setters gerados ou records. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <!-- Campos injetados pelo Spring e inicializados em construtores/métodos de configuração. -->
    <Match>
        <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
    </Match>
    <!-- Validação de domínio em construtores de entidades (padrão atual do projeto). -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
    <!-- SecureRandom local em helpers de token; aceitável na primeira rodada. -->
    <Match>
        <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
    </Match>
    <!-- Mensagens de e-mail usam quebra de linha explícita. -->
    <Match>
        <Bug pattern="VA_FORMAT_STRING_USES_NEWLINE"/>
    </Match>
    <!-- Catch defensivo ao normalizar tipos de drivers JDBC. -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>
    <!-- Boxing em projeções nativas de relatório. -->
    <Match>
        <Bug pattern="BX_UNBOXING_IMMEDIATELY_REBOXED"/>
    </Match>
</FindBugsFilter>
